{
  "required": true,
  "minVersion": "0.8",
  "package": "net.mikuas.interval.mixin",
  "compatibilityLevel": "JAVA_21",
  "mixins": [
    "AbstractFurnaceBlockEntityMixin",
    "ExampleMixin"
  ],
  "client": [
    "ItemRendererAccessor",
    "ItemRendererMixin"
  ],
  "injectors": {
    "defaultRequire": 1
  },
  "overwrites": {
    "requireAnnotations": true
  }
}
